{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "allowJs": true,
        "moduleResolution": "nodenext",
        "baseUrl": "./",
        "paths": {
            "@internal/*": [
                "functions/internal/*"
            ]
        }
    },
    "include": [
        "worker-configuration.d.ts",
        "functions/**/*.ts"
    ]
}